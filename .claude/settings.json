{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(cargo:*)"
    ],
    "deny": ["Bash(git -C:*)", "Bash(git push:*)"],
    "defaultMode": "acceptEdits"
  }
}
